    private async Task ProcessarArquivo(IBrowserFile file)
    {
        if (file == null) return;
        try
        {
            var client    = ClientFactory.CreateClient("ClientesAPI");
            var culturaBR = new CultureInfo("pt-BR");
            using var reader = new System.IO.StreamReader(file.OpenReadStream());
            var linhas = (await reader.ReadToEndAsync())
                .Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries)
                .Skip(1);

            var novasTransacoes = new List<Transacao>();
            foreach (var linha in linhas)
            {
                if (string.IsNullOrWhiteSpace(linha)) continue;
                var limpa = linha.Replace("\"", "");
                var sep   = limpa.Contains(";") ? ';' : ',';
                var cols  = limpa.Split(sep);
                if (cols.Length < 3) continue;

                var valorTexto = cols[2].Replace("R$", "").Trim();
                decimal valor;
                if (!decimal.TryParse(valorTexto.Replace(",", "."), System.Globalization.NumberStyles.Any, CultureInfo.InvariantCulture, out valor))
                    decimal.TryParse(valorTexto, System.Globalization.NumberStyles.Any, culturaBR, out valor);

                var desc     = cols[1].Trim();
                var ehStudio = desc.Contains("SECRETSTUDIO") || desc.Contains("MAQUIAGEM") || desc.Contains("STUDIO");

                novasTransacoes.Add(new Transacao
                {
                    Data        = DateTime.Parse(cols[0].Trim(), culturaBR),
                    Descricao   = desc,
                    Valor       = valor,
                    Responsavel = ehStudio ? "Namorada" : "Eu",
                    EhPessoal   = !ehStudio,
                    Categoria   = "Importação CSV",
                    Tipo        = valor < 0 ? "Saída" : "Entrada"
                });
            }

            var response = await client.PostAsJsonAsync("api/transacoes/lote", novasTransacoes);
            if (response.IsSuccessStatusCode) { Snackbar.Add($"{novasTransacoes.Count} transações importadas! 🚀", Severity.Success); Cache.Invalidar(); await CarregarTudo(forcarAtualizacao: true); }
            else Snackbar.Add($"Erro: {await response.Content.ReadAsStringAsync()}", Severity.Error);
        }
        catch (Exception ex) { Snackbar.Add($"Erro: {ex.Message}", Severity.Error); }
    }

    private async Task AnalisarComprovanteOCR(IBrowserFile file)
    {
        if (file == null) return;
        try
        {
            _loading = true;
            StateHasChanged();
            var client = ClientFactory.CreateClient("ClientesAPI");
            using var form        = new MultipartFormDataContent();
            var       fileContent = new StreamContent(file.OpenReadStream(maxAllowedSize: 1024 * 1024 * 15));
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            form.Add(fileContent, "file", file.Name);

            var response = await client.PostAsync("api/ocr/analisar", form);
            if (!response.IsSuccessStatusCode) { Snackbar.Add($"Erro: {await response.Content.ReadAsStringAsync()}", Severity.Error); return; }

            var json = await response.Content.ReadFromJsonAsync<System.Text.Json.JsonElement>();
            string texto = "";
            if (json.TryGetProperty("TextoBruto", out var p1))      texto = p1.GetString() ?? "";
            else if (json.TryGetProperty("textoBruto", out var p2)) texto = p2.GetString() ?? "";
            if (string.IsNullOrEmpty(texto)) { Snackbar.Add("Texto não identificado.", Severity.Warning); return; }

            var mValor = System.Text.RegularExpressions.Regex.Match(texto,
                @"(?:R\$|VALOR|TOTAL)?\s*(\d{1,3}(?:\.\d{3})*,\d{2})",
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
            decimal valorOCR = 0;
            if (mValor.Success)
            {
                var v = mValor.Groups[1].Value.Replace(".", "").Replace(",", ".");
                decimal.TryParse(v, System.Globalization.NumberStyles.Any, CultureInfo.InvariantCulture, out valorOCR);
            }

            var mData = System.Text.RegularExpressions.Regex.Match(texto, @"(\d{2}/\d{2}/\d{4})");
            DateTime dataOCR = DateTime.Now;
            if (mData.Success) DateTime.TryParse(mData.Groups[1].Value, new CultureInfo("pt-BR"), DateTimeStyles.None, out dataOCR);

            bool ehStudio = texto.ToUpper().Contains("STUDIO") || texto.ToUpper().Contains("SECRET");
            transacaoOCR = new Transacao
            {
                Data        = dataOCR,
                Valor       = valorOCR,
                Descricao   = ehStudio ? "Venda Studio (OCR)" : "Gasto via OCR",
                Responsavel = ehStudio ? "Namorada" : "Eu",
                EhPessoal   = !ehStudio,
                Tipo        = ehStudio ? "Entrada" : "Saída",
                Categoria   = ehStudio ? "Faturamento" : "Variáveis"
            };
            _modalOCRAberto = true;
        }
        catch (Exception ex) { Snackbar.Add($"Erro: {ex.Message}", Severity.Error); }
        finally { _loading = false; StateHasChanged(); }
    }

    private async Task SalvarTransacaoOCR()
    {
        if (transacaoOCR.Tipo == "Saída" && transacaoOCR.Valor > 0) transacaoOCR.Valor *= -1;
        var response = await ClientFactory.CreateClient("ClientesAPI").PostAsJsonAsync("api/transacoes", transacaoOCR);
        if (response.IsSuccessStatusCode) { _modalOCRAberto = false; Cache.Invalidar(); await CarregarTudo(forcarAtualizacao: true); Snackbar.Add("Transação salva! 💸", Severity.Success); }
        else Snackbar.Add("Erro ao salvar transação OCR.", Severity.Error);
    }

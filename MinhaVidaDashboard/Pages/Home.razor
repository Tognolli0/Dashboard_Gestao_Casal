@page "/"
@using System.Globalization
@using MudBlazor
@using MinhaVidaDashboard.Models
@inject IHttpClientFactory ClientFactory
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject MinhaVidaDashboard.Services.CacheService Cache

<PageTitle>Dashboard Consolidado ❤️</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-8">

    @if (_loading)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
    }

    @* --- CARDS DE RESUMO --- *@
    <MudGrid Class="mb-8">
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-6 d-flex flex-column align-center" Elevation="4"
                      Style="border-radius:20px; border-bottom:6px solid #5C6BC0; background:#ffffff;">
                <MudText Typo="Typo.overline" Style="font-weight:700; color:#5C6BC0;">MEU PATRIMÔNIO</MudText>
                <MudText Typo="Typo.h4" Style="font-weight:900; color:#3f51b5;">
                    @((saldoEuPessoal + saldoEuBusiness).ToString("C"))
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-6 d-flex flex-column align-center" Elevation="4"
                      Style="border-radius:20px; border-bottom:6px solid #E91E63; background:#ffffff;">
                <MudText Typo="Typo.overline" Style="font-weight:700; color:#E91E63;">PATRIMÔNIO DELA</MudText>
                <MudText Typo="Typo.h4" Style="font-weight:900; color:#d81b60;">
                    @((saldoDelaPessoal + saldoDelaBusiness).ToString("C"))
                </MudText>
            </MudPaper>
        </MudItem>
        <MudItem xs="12" sm="4">
            <MudPaper Class="pa-6 d-flex flex-column align-center" Elevation="8"
                      Style="border-radius:20px; background:linear-gradient(135deg,#f1f8e9 0%,#dcedc8 100%); border:1px solid #aed581;">
                <MudText Typo="Typo.overline" Style="font-weight:700; color:#33691e;">TOTAL CONSOLIDADO</MudText>
                <MudText Typo="Typo.h4" Style="font-weight:900; color:#1b5e20;">
                    @totalPatrimonio.ToString("C")
                </MudText>
            </MudPaper>
        </MudItem>
    </MudGrid>

    <MudTabs Elevation="4" Rounded="true" ApplyEffectsToContainer="true" Color="Color.Primary" PanelClass="pa-8">

        @* --- ABA 1: VISÃO PATRIMONIAL --- *@
        <MudTabPanel Text="Visão Patrimonial" Icon="@Icons.Material.Filled.StackedBarChart">
            <MudGrid>
                <MudItem xs="12">
                    <MudPaper Class="pa-8" Elevation="4" Style="border-radius:24px;">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-8">
                            <MudText Typo="Typo.h5" Color="Color.Primary" Style="font-weight:800;">
                                <MudIcon Icon="@Icons.Material.Filled.Home" Class="mr-2 mb-n1" />
                                Vida Pessoal & Reserva Conjunta
                            </MudText>
                            <div style="background:#e8f5e9; padding:10px 20px; border-radius:12px; border:1px solid #4caf50;">
                                <MudText Typo="Typo.h6" Color="Color.Success" Style="font-weight:800;">
                                    TOTAL: @((saldoEuPessoal + saldoDelaPessoal + saldoJuntos).ToString("C"))
                                </MudText>
                            </div>
                        </MudStack>
                        <div class="grafico-foco" style="width:100%;">
                            <MudChart T="double" ChartType="ChartType.Bar" Width="100%" Height="550px"
                                      ChartSeries="@SeriesPessoal" ChartOptions="@_optionsPessoal"
                                      LegendPosition="Position.Bottom" />
                        </div>
                    </MudPaper>
                </MudItem>
                <MudItem xs="12">
                    <MudPaper Class="pa-8" Elevation="4" Style="border-radius:24px;">
                        <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-8">
                            <MudText Typo="Typo.h5" Color="Color.Info" Style="font-weight:800;">
                                <MudIcon Icon="@Icons.Material.Filled.BusinessCenter" Class="mr-2 mb-n1" />
                                Nossos Empreendimentos (Empresa & Studio)
                            </MudText>
                            <div style="background:#e3f2fd; padding:10px 20px; border-radius:12px; border:1px solid #2196f3;">
                                <MudText Typo="Typo.h6" Color="Color.Info" Style="font-weight:800;">
                                    TOTAL: @((saldoEuBusiness + saldoDelaBusiness).ToString("C"))
                                </MudText>
                            </div>
                        </MudStack>
                        <div class="grafico-foco" style="width:100%;">
                            <MudChart T="double" ChartType="ChartType.Bar" Width="100%" Height="550px"
                                      ChartSeries="@SeriesBusiness" ChartOptions="@_optionsBusiness"
                                      LegendPosition="Position.Bottom" />
                        </div>
                    </MudPaper>
                </MudItem>
            </MudGrid>
        </MudTabPanel>

        @* --- ABA 2: METAS --- *@
        <MudTabPanel Text="Metas e Sonhos" Icon="@Icons.Material.Filled.AutoAwesome">
            <div class="pa-4">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-8">
                    <MudText Typo="Typo.h5" Style="font-weight:700;">Nossos Objetivos 🎯</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Add" OnClick="AbrirModalMeta" Size="Size.Large">
                        Nova Meta
                    </MudButton>
                </MudStack>
                <MudGrid>
                    @foreach (var meta in ListaMetas)
                    {
                        var porcentagem = meta.ValorObjetivo > 0 ? (meta.ValorGuardado / meta.ValorObjetivo * 100) : 0;
                        <MudItem xs="12" md="6">
                            <MudPaper Class="pa-6" Elevation="3" Style="position:relative; border-radius:20px;">
                                <MudStack Row="true" Justify="Justify.FlexEnd"
                                          Style="position:absolute; top:10px; right:10px;">
                                    <MudIconButton Icon="@Icons.Material.Filled.AddCard" Color="Color.Success"
                                                   OnClick="@(() => AbrirModalAporte(meta))" />
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                   OnClick="@(() => ExcluirMeta(meta))" />
                                </MudStack>
                                <MudText Typo="Typo.h6">@meta.Titulo</MudText>
                                <MudText Typo="Typo.h4" Color="Color.Primary" Style="font-weight:900;" Class="my-2">
                                    @porcentagem.ToString("F1")%
                                </MudText>
                                <MudProgressLinear Color="porcentagem >= 100 ? Color.Success : Color.Primary"
                                                   Value="@meta.ValorGuardado" Max="@meta.ValorObjetivo"
                                                   Size="Size.Large" Class="my-4" Rounded="true" Style="height:12px;" />
                                <MudStack Row="true" Justify="Justify.SpaceBetween">
                                    <MudText Typo="Typo.body1"><b>@meta.ValorGuardado.ToString("C")</b> guardados</MudText>
                                    <MudText Typo="Typo.body2" Color="Color.Secondary">Objetivo: @meta.ValorObjetivo.ToString("C")</MudText>
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </div>
        </MudTabPanel>

        @* --- ABA 3: EVOLUÇÃO MENSAL --- *@
        <MudTabPanel Text="Evolução" Icon="@Icons.Material.Filled.TrendingUp">
            <MudPaper Class="pa-6" Elevation="4" Style="border-radius:24px;">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-6">
                    <div>
                        <MudText Typo="Typo.h5" Style="font-weight:800;">
                            <MudIcon Icon="@Icons.Material.Filled.TrendingUp" Class="mr-2 mb-n1" Color="Color.Success" />
                            Evolução do Patrimônio @DateTime.Now.Year
                        </MudText>
                        <MudText Typo="Typo.body2" Color="Color.Dark">Crescimento acumulado mês a mês</MudText>
                    </div>
                    <div style="background:#e8f5e9; padding:10px 20px; border-radius:12px; border:1px solid #4caf50;">
                        <MudText Typo="Typo.caption" Style="color:#2e7d32; font-weight:700; display:block;">CRESCIMENTO NO ANO</MudText>
                        <MudText Typo="Typo.h6" Style="font-weight:900; color:#1b5e20;">
                            @crescimentoAno.ToString("C")
                        </MudText>
                    </div>
                </MudStack>

                @* Gráfico de linha *@
                <MudChart T="double" ChartType="ChartType.Line" Width="100%" Height="400px"
                          ChartSeries="@SeriesEvolucao" XAxisLabels="@mesesLabels"
                          ChartOptions="@_optionsEvolucao" LegendPosition="Position.Bottom" />

                @* Cards de resumo por mês *@
                <MudDivider Class="my-6" />
                <MudText Typo="Typo.subtitle1" Style="font-weight:700; margin-bottom:16px;">Resumo por Mês</MudText>
                <div style="overflow-x:auto;">
                    <MudTable Items="@resumoMensal" Hover="true" Dense="true" Elevation="0">
                        <HeaderContent>
                            <MudTh>Mês</MudTh>
                            <MudTh Style="text-align:right">Eu</MudTh>
                            <MudTh Style="text-align:right">Ela</MudTh>
                            <MudTh Style="text-align:right">Total</MudTh>
                            <MudTh Style="text-align:right">Variação</MudTh>
                        </HeaderContent>
                        <RowTemplate>
                            <MudTd Style="font-weight:600;">@context.NomeMes</MudTd>
                            <MudTd Style="text-align:right;">@context.SaldoEu.ToString("C")</MudTd>
                            <MudTd Style="text-align:right;">@context.SaldoDela.ToString("C")</MudTd>
                            <MudTd Style="text-align:right; font-weight:700;">@context.Total.ToString("C")</MudTd>
                            <MudTd Style="@($"text-align:right; font-weight:700; color:{(context.Variacao >= 0 ? "#2e7d32" : "#d32f2f")};")">
                                @(context.Variacao >= 0 ? "+" : "")@context.Variacao.ToString("C")
                            </MudTd>
                        </RowTemplate>
                    </MudTable>
                </div>
            </MudPaper>
        </MudTabPanel>

        @* --- ABA 4: BUCKET LIST --- *@
        <MudTabPanel Text="Bucket List" Icon="@Icons.Material.Filled.Flight">
            <div class="pa-4">
                <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="mb-8">
                    <MudText Typo="Typo.h5" Style="font-weight:800;">Nossa Bucket List ✈️</MudText>
                    <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Add" OnClick="AbrirModalDesejo" Size="Size.Large">
                        Novo Item
                    </MudButton>
                </MudStack>
                <MudGrid>
                    @foreach (var item in ListaDesejos)
                    {
                        <MudItem xs="12" sm="6" md="4">
                            <MudPaper Class="pa-4" Elevation="4"
                                      Style="@(item.Concluido ? "opacity:0.6; border-left:8px solid #4caf50;" : "border-left:8px solid #ff4081;")">
                                <MudStack Row="true" AlignItems="AlignItems.Center">
                                    <MudIcon Icon="@GetIcon(item.Icone)"
                                             Color="@(item.Concluido ? Color.Success : Color.Secondary)"
                                             Size="Size.Large" />
                                    <MudStack Spacing="0" Style="flex-grow:1;">
                                        <MudText Typo="Typo.h6">@item.Titulo</MudText>
                                        @if (!item.Concluido)
                                        {
                                            var diasRestantes = (item.DataAlvo - DateTime.Now).Days;
                                            <MudText Typo="Typo.caption" Color="Color.Info">
                                                <b>@(diasRestantes > 0 ? diasRestantes : 0) dias</b> restantes!
                                            </MudText>
                                        }
                                        else
                                        {
                                            <MudText Typo="Typo.caption" Color="Color.Success">
                                                Realizado em @item.DataAlvo.ToShortDateString()!
                                            </MudText>
                                        }
                                    </MudStack>
                                    <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error"
                                                   Size="Size.Small" OnClick="@(() => ExcluirDesejo(item))" />
                                </MudStack>
                            </MudPaper>
                        </MudItem>
                    }
                </MudGrid>
            </div>
        </MudTabPanel>
    </MudTabs>

    @* --- UPLOAD CSV E OCR --- *@
    <div class="d-flex mt-4">
        <MudFileUpload T="IBrowserFile" FilesChanged="ProcessarArquivo">
            <ButtonTemplate Context="__">
                <MudButton Variant="Variant.Filled" Color="Color.Info"
                           StartIcon="@Icons.Material.Filled.CloudUpload">
                    Selecionar CSV
                </MudButton>
            </ButtonTemplate>
        </MudFileUpload>

        <MudFileUpload T="IBrowserFile" FilesChanged="AnalisarComprovanteOCR"
                       Accept=".jpg,.png,.jpeg" Class="ml-2">
            <ButtonTemplate Context="__">
                <MudButton Variant="Variant.Filled" Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.CameraEnhance">
                    Tirar Foto / Galeria
                </MudButton>
            </ButtonTemplate>
        </MudFileUpload>
    </div>

</MudContainer>

@* --- MODAIS --- *@
<MudDialog @bind-Visible="_modalAberto" Options="_dialogOptions">
    <TitleContent><MudText Typo="Typo.h6">Novo Sonho Financeiro</MudText></TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="novaMeta.Titulo" Label="Descrição" Variant="Variant.Outlined" Class="mb-4" />
        <MudNumericField @bind-Value="novaMeta.ValorObjetivo" Label="Valor Alvo" Variant="Variant.Outlined"
                         Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Flag" Class="mb-4" />
        <MudNumericField @bind-Value="novaMeta.ValorGuardado" Label="Quanto já temos guardado?"
                         Variant="Variant.Outlined" Adornment="Adornment.Start"
                         AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _modalAberto = false">Cancelar</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="SalvarMeta">Salvar e Notificar 🚀</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_modalAporteAberto" Options="_dialogOptions">
    <TitleContent><MudText Typo="Typo.h6">Novo Aporte 💰</MudText></TitleContent>
    <DialogContent>
        <MudText Typo="Typo.body1" Class="mb-4">Meta: <b>@metaSelecionada.Titulo</b></MudText>
        <MudNumericField @bind-Value="valorAporte" Label="Valor para Guardar" Variant="Variant.Outlined"
                         Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _modalAporteAberto = false">Cancelar</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="ConfirmarAporte">Confirmar e Enviar Zap 📲</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_modalDesejoAberto" Options="_dialogOptions">
    <TitleContent><MudText Typo="Typo.h6">Novo Desejo da Lista</MudText></TitleContent>
    <DialogContent>
        <MudTextField @bind-Value="novoDesejo.Titulo" Label="O que queremos fazer?"
                      Variant="Variant.Outlined" Class="mb-4" />
        <MudDatePicker Label="Data Alvo" @bind-Date="dataAlvoAux" Variant="Variant.Outlined" Class="mb-4" />
        <MudSelect T="string" Label="Ícone" @bind-Value="novoDesejo.Icone" Variant="Variant.Outlined">
            <MudSelectItem Value="@("Flight")">Viagem</MudSelectItem>
            <MudSelectItem Value="@("Favorite")">Romance</MudSelectItem>
            <MudSelectItem Value="@("Camera")">Foto/Evento</MudSelectItem>
            <MudSelectItem Value="@("Hotel")">Hospedagem</MudSelectItem>
        </MudSelect>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _modalDesejoAberto = false">Cancelar</MudButton>
        <MudButton Color="Color.Secondary" Variant="Variant.Filled" OnClick="SalvarDesejo">Adicionar</MudButton>
    </DialogActions>
</MudDialog>

<MudDialog @bind-Visible="_modalOCRAberto" Options="_dialogOptions">
    <TitleContent><MudText Typo="Typo.h6">Confirmar Lançamento OCR 📸</MudText></TitleContent>
    <DialogContent>
        <MudStack Spacing="4">
            <MudDatePicker Label="Data do Comprovante" @bind-Date="dataOCRAux" Variant="Variant.Outlined" />
            <MudTextField @bind-Value="transacaoOCR.Descricao" Label="Descrição" Variant="Variant.Outlined" />
            <MudNumericField @bind-Value="transacaoOCR.Valor" Label="Valor Extraído" Variant="Variant.Outlined"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.AttachMoney" />
            <MudSelect T="string" Label="Quem pagou?" @bind-Value="transacaoOCR.Responsavel" Variant="Variant.Outlined">
                <MudSelectItem Value="@("Eu")">Eu</MudSelectItem>
                <MudSelectItem Value="@("Namorada")">Namorada</MudSelectItem>
            </MudSelect>
            <MudSwitch @bind-Value="transacaoOCR.EhPessoal" Color="Color.Primary"
                       Label="Gasto Pessoal (se desmarcar, vai para Business)" />
        </MudStack>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="() => _modalOCRAberto = false">Cancelar</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled" OnClick="SalvarTransacaoOCR">Salvar no Banco ✅</MudButton>
    </DialogActions>
</MudDialog>

@code {
    private bool _loading = false;
    private bool _modalAberto;
    private bool _modalDesejoAberto;
    private bool _modalAporteAberto;
    private bool _modalOCRAberto;

    private double saldoEuPessoal, saldoEuBusiness, saldoDelaPessoal, saldoDelaBusiness, saldoJuntos;

    private Meta   novaMeta        = new();
    private Meta   metaSelecionada = new();
    private double valorAporte;
    private List<Meta>   ListaMetas   = new();
    private List<Desejo> ListaDesejos = new();
    private Desejo novoDesejo = new();

    private Transacao transacaoOCR = new();
    private DateTime? dataOCRAux  { get => transacaoOCR.Data;   set => transacaoOCR.Data   = value ?? DateTime.Now; }
    private DateTime? dataAlvoAux { get => novoDesejo.DataAlvo; set => novoDesejo.DataAlvo = value ?? DateTime.Now; }

    private readonly DialogOptions _dialogOptions   = new() { FullWidth = true, MaxWidth = MaxWidth.Small };
    private readonly ChartOptions  _optionsPessoal  = new() { ChartPalette = new[] { "#5C6BC0", "#E91E63", "#4CAF50" } };
    private readonly ChartOptions  _optionsBusiness = new() { ChartPalette = new[] { "#3F51B5", "#C2185B" } };

    public List<ChartSeries<double>> SeriesPessoal  = new();
    public List<ChartSeries<double>> SeriesBusiness = new();
    public List<ChartSeries<double>> SeriesEvolucao = new();

    private string[] mesesLabels = Array.Empty<string>();
    private double   crescimentoAno = 0;
    private List<ResumoMensal> resumoMensal = new();

    private readonly ChartOptions _optionsEvolucao = new()
    {
        ChartPalette = new[] { "#5C6BC0", "#4CAF50", "#E91E63", "#FF9800", "#9C27B0" }
    };

    private double totalPatrimonio =>
        saldoEuPessoal + saldoEuBusiness + saldoDelaPessoal + saldoDelaBusiness + saldoJuntos;

    protected override async Task OnInitializedAsync() => await CarregarTudo();

    private async Task CarregarTudo(bool forcarAtualizacao = false)
    {
        // Se tem cache válido e não é forçado, usa cache — navegação instantânea
        var cached = forcarAtualizacao ? null : Cache.ObterCache();
        if (cached != null)
        {
            AplicarDados(cached.TransacoesEu, cached.TransacoesDela, cached.Metas, cached.Desejos);
            return;
        }

        _loading = true;
        StateHasChanged();
        try
        {
            var client = ClientFactory.CreateClient("ClientesAPI");
            var resumo = await client.GetFromJsonAsync<DashboardResumo>("api/dashboard/resumo");
            if (resumo == null) return;

            var eu   = resumo.TransacoesEu   ?? new();
            var dela = resumo.TransacoesDela ?? new();
            ListaMetas   = resumo.Metas   ?? new();
            ListaDesejos = resumo.Desejos ?? new();

            // Salva no cache para próximas navegações
            Cache.SalvarCache(new MinhaVidaDashboard.Services.DashboardCache
            {
                TransacoesEu   = eu,
                TransacoesDela = dela,
                Metas          = ListaMetas,
                Desejos        = ListaDesejos
            });

            AplicarDados(eu, dela, ListaMetas, ListaDesejos);
        }
        catch (Exception ex)
        {
            Snackbar.Add("Erro ao carregar dados. Verifique se a API está rodando.", Severity.Error);
            Console.WriteLine($"Erro: {ex.Message}");
        }
        finally
        {
            _loading = false;
            StateHasChanged();
        }
    }

    private void AplicarDados(List<Transacao> eu, List<Transacao> dela, List<Meta> metas, List<Desejo> desejos)
    {
        ListaMetas   = metas;
        ListaDesejos = desejos;

        saldoEuPessoal    = SomarSaldo(eu,   true);
        saldoEuBusiness   = SomarSaldo(eu,   false);
        saldoDelaPessoal  = SomarSaldo(dela, true);
        saldoDelaBusiness = SomarSaldo(dela, false);
        saldoJuntos = 0;

        SeriesPessoal = new List<ChartSeries<double>>
        {
            new() { Name = "Eu",       Data = new double[] { Math.Max(0, saldoEuPessoal) } },
            new() { Name = "Dela",     Data = new double[] { Math.Max(0, saldoDelaPessoal) } },
            new() { Name = "Conjunto", Data = new double[] { saldoJuntos } }
        };
        SeriesBusiness = new List<ChartSeries<double>>
        {
            new() { Name = "Minha Empresa", Data = new double[] { Math.Max(0, saldoEuBusiness) } },
            new() { Name = "Studio Dela",   Data = new double[] { Math.Max(0, saldoDelaBusiness) } }
        };

        // Calcula evolução mensal acumulada
        CalcularEvolucao(eu, dela);

        StateHasChanged();
    }

    private void CalcularEvolucao(List<Transacao> eu, List<Transacao> dela)
    {
        var anoAtual = DateTime.Now.Year;
        var cultura  = new System.Globalization.CultureInfo("pt-BR");
        var meses    = Enumerable.Range(1, 12).ToList();

        // Para cada mês, calcula o saldo ACUMULADO até aquele mês
        var dadosEu        = new double[12];
        var dadosDela      = new double[12];
        var dadosTotal     = new double[12];
        var dadosPessoal   = new double[12];
        var dadosBusiness  = new double[12];

        for (int i = 0; i < 12; i++)
        {
            int mes = i + 1;

            // Acumulado: todas as transações até este mês inclusive
            var transEuAte   = eu.Where(t   => t.Data.Year == anoAtual && t.Data.Month <= mes).ToList();
            var transDelaAte = dela.Where(t => t.Data.Year == anoAtual && t.Data.Month <= mes).ToList();

            dadosEu[i]       = SomarSaldo(transEuAte,   true)  + SomarSaldo(transEuAte,   false);
            dadosDela[i]     = SomarSaldo(transDelaAte, true)  + SomarSaldo(transDelaAte, false);
            dadosTotal[i]    = dadosEu[i] + dadosDela[i];
            dadosPessoal[i]  = SomarSaldo(transEuAte, true)   + SomarSaldo(transDelaAte, true);
            dadosBusiness[i] = SomarSaldo(transEuAte, false)  + SomarSaldo(transDelaAte, false);
        }

        mesesLabels = meses
            .Select(m => new DateTime(anoAtual, m, 1).ToString("MMM", cultura))
            .ToArray();

        SeriesEvolucao = new List<ChartSeries<double>>
        {
            new() { Name = "Total",    Data = dadosTotal },
            new() { Name = "Eu",       Data = dadosEu },
            new() { Name = "Ela",      Data = dadosDela },
            new() { Name = "Pessoal",  Data = dadosPessoal },
            new() { Name = "Business", Data = dadosBusiness },
        };

        // Crescimento = total acumulado do mês atual
        var mesAtual = DateTime.Now.Month - 1;
        crescimentoAno = dadosTotal[mesAtual];

        // Tabela de resumo mensal
        resumoMensal = new List<ResumoMensal>();
        double totalAnterior = 0;
        for (int i = 0; i < DateTime.Now.Month; i++)
        {
            var variacao = dadosTotal[i] - totalAnterior;
            resumoMensal.Add(new ResumoMensal
            {
                NomeMes  = new DateTime(anoAtual, i + 1, 1).ToString("MMMM", cultura),
                SaldoEu  = dadosEu[i],
                SaldoDela = dadosDela[i],
                Total    = dadosTotal[i],
                Variacao = variacao
            });
            totalAnterior = dadosTotal[i];
        }
        // Mais recente primeiro
        resumoMensal.Reverse();
    }


@inherits LayoutComponentBase

<MudThemeProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<MudLayout>
    <MudAppBar Elevation="1" Color="Color.Primary">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@((e) => DrawerToggle())" />
        <MudText Typo="Typo.h5" Class="ml-3">Nossa Gestão Financeira 🏠</MudText>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" ClipMode="DrawerClipMode.Always" Elevation="2">
        <MudNavMenu>
            <MudText Typo="Typo.subtitle2" Color="Color.Primary" Class="ml-4 mt-3 mb-2">GERAL</MudText>
            <MudNavLink href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Visão Casal</MudNavLink>
            <MudNavLink href="/meu-espaco" Icon="@Icons.Material.Filled.Person">Meu Espaço</MudNavLink>
            <MudNavLink href="/espaco-dela" Icon="@Icons.Material.Filled.AutoAwesome">Espaço Dela</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="my-4">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

<style>
    /* Força o container do gráfico a ter altura */
    .mud-chart.mud-chart-bar {
        height: 350px !important;
        width: 100% !important;
    }
</style>

@code {
    bool _drawerOpen = true;
    void DrawerToggle() => _drawerOpen = !_drawerOpen;
}